# 图谱模式：neo4j（正式答辩，需 Neo4j Desktop）| local（仅临时预览界面）
GRAPH_MODE=neo4j

# Neo4j 图数据库配置（仅 GRAPH_MODE=neo4j 时需要）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kgqa123456

# 可选：大模型 API（OpenAI 兼容接口，如 DeepSeek、通义千问等）
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
# rich=图谱锚定+常识扩展（推荐）| strict=仅复述图谱
LLM_ANSWER_STYLE=rich
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# 服务配置
API_HOST=0.0.0.0
API_PORT=8001
